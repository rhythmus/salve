{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://salve.dev/schemas/greeting-pack.schema.json",
    "title": "Salve Greeting Pack",
    "description": "A locale-specific collection of greeting strings for the Salve greeting engine. Each pack is the single source of truth for one locale's greetings.",
    "type": "object",
    "required": [
        "locale",
        "greetings"
    ],
    "properties": {
        "$schema": {
            "type": "string",
            "description": "JSON Schema reference (for editor validation)"
        },
        "locale": {
            "type": "string",
            "description": "BCP 47 locale identifier (e.g. 'de-DE', 'el-GR', 'ar')",
            "pattern": "^[a-z]{2,3}(-[A-Z]{2})?(-[A-Za-z0-9]+)*$"
        },
        "extends": {
            "type": "string",
            "description": "Optional parent locale for inheritance (e.g. 'de' for 'de-AT')"
        },
        "sources": {
            "oneOf": [
                {
                    "type": "string"
                },
                {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            ],
            "description": "Default source URL(s) or bibliographic reference(s) for all greetings in this pack"
        },
        "greetings": {
            "type": "array",
            "description": "Ordered list of greeting entries for this locale",
            "items": {
                "$ref": "#/$defs/GreetingEntry"
            },
            "minItems": 1
        }
    },
    "additionalProperties": false,
    "$defs": {
        "GreetingEntry": {
            "type": "object",
            "description": "A single greeting string with optional context constraints",
            "required": [
                "text"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "description": "Stable unique identifier within this pack (e.g. 'de_morning'). If omitted in YAML, it will be auto-generated."
                },
                "text": {
                    "oneOf": [
                        {
                            "type": "string",
                            "minLength": 1
                        },
                        {
                            "type": "array",
                            "items": {
                                "type": "string",
                                "minLength": 1
                            },
                            "minItems": 1
                        }
                    ],
                    "description": "The greeting phrase or an array of variants"
                },
                "eventRef": {
                    "type": "string",
                    "description": "Links to a CelebrationEvent ID (e.g. 'morning', 'christmas', 'eid_al_fitr')"
                },
                "expectedResponse": {
                    "type": "string",
                    "description": "Expected response in call–response pairs (e.g. Easter: Χριστός ἀνέστη → Ἀληθῶς ἀνέστη)"
                },
                "formality": {
                    "type": "string",
                    "enum": [
                        "informal",
                        "highly informal",
                        "formal",
                        "hyperformal",
                        "neutral"
                    ],
                    "description": "Formality constraint"
                },
                "timeOfDay": {
                    "oneOf": [
                        {
                            "type": "string",
                            "enum": [
                                "morning",
                                "midday",
                                "afternoon",
                                "evening",
                                "night"
                            ]
                        },
                        {
                            "type": "array",
                            "items": {
                                "type": "string",
                                "enum": [
                                    "morning",
                                    "midday",
                                    "afternoon",
                                    "evening",
                                    "night"
                                ]
                            }
                        }
                    ],
                    "description": "Chronemic constraints"
                },
                "audienceSize": {
                    "oneOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "integer"
                        }
                    ],
                    "description": "Numerical or computable audience size constraint (e.g. '>4', '2', '1')"
                },
                "locale": {
                    "oneOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        }
                    ],
                    "description": "Optional BCP 47 compliant language/dialect tag(s) for this specific greeting"
                },
                "phase": {
                    "oneOf": [
                        {
                            "type": "string",
                            "enum": [
                                "encounter",
                                "parting"
                            ]
                        },
                        {
                            "type": "array",
                            "items": {
                                "type": "string",
                                "enum": [
                                    "encounter",
                                    "parting"
                                ]
                            }
                        }
                    ],
                    "description": "Session phase constraint"
                },
                "role": {
                    "type": "string",
                    "enum": [
                        "initiator",
                        "responder"
                    ],
                    "description": "Interaction role constraint"
                },
                "relationship": {
                    "oneOf": [
                        {
                            "type": "string",
                            "enum": [
                                "stranger",
                                "acquaintance",
                                "friend",
                                "family",
                                "intimate",
                                "superior",
                                "subordinate"
                            ]
                        },
                        {
                            "type": "array",
                            "items": {
                                "type": "string",
                                "enum": [
                                    "stranger",
                                    "acquaintance",
                                    "friend",
                                    "family",
                                    "intimate",
                                    "superior",
                                    "subordinate"
                                ]
                            }
                        }
                    ],
                    "description": "Applicable relationship contexts"
                },
                "setting": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "direct_address",
                            "group_address",
                            "public_announcement",
                            "chat_message",
                            "email_opening",
                            "email_closing",
                            "phone"
                        ]
                    },
                    "description": "Applicable interaction settings"
                },
                "notes": {
                    "oneOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        }
                    ],
                    "description": "Internal developer notes or context"
                },
                "sources": {
                    "oneOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        }
                    ],
                    "description": "Source URL(s) or bibliographic reference(s)"
                }
            },
            "additionalProperties": {
                "oneOf": [
                    {
                        "type": "string"
                    },
                    {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                ]
            }
        }
    }
}